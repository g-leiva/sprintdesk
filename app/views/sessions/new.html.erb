<div>
    <h1>Iniciar sesión</h1>
    <% if flash[:alert] %>
        <p><%= flash[:alert] %></p>
    <% end %>

    <%= form_with url: login_path do |f| %>
        <div>
          <%= f.label :email, "Email" %>
          <%= f.email_field :email, required: true, autofocus: true %>
        </div>

        <div>
            <%= f.label :password, "Contraseña" %>
            <%= f.password_field :password, required:true %>
        </div>

        <%= f.submit "Iniciar sesión" %>
    <% end %>

    <p>No tienes una cuenta? <%= link_to "Registrarme", signup_path %></p>
</div>
